	<IED xmlns="http://www.iec.ch/61850/2003/SCL" name="Gateway" desc="SCADA HMI Gateway" type="Gateway" manufacturer="Generic" configVersion="1" originalSclVersion="2026" originalSclRevision="" originalSclRelease="">
		<!-- ===== Services exposed for engineering ===== -->
		<Services nameLength="64">
			<ClientServices bufReport="true" unbufReport="true" supportsLdName="true" maxAttributes="65535" maxReports="65535">
				<TimeSyncProt sntp="true">
					<!--CD HQ hint: true if Windows NTP client service is enbled and iec850 variable TimeQuality handling projected  -->
				</TimeSyncProt>
			</ClientServices>
		</Services>
		<AccessPoint name="Z1" desc="zenon Network: IEC61850 Client on SCADA Server1">
			<LN lnClass="IHMI" inst="1" lnType="IHMI_zenon">
				<!--from 61850-7-4: Human machine interface (e.g. to operator) -->
				<DOI name="Beh">
					<DAI name="stVal" valKind="RO">
						<Val>on</Val>
					</DAI>
				</DOI>
			</LN>
			<LN lnClass="ITCI" inst="1" lnType="ITCI_zenon">
				<!--from 61850-7-4: Telecontrol (remote control) interface -->
				<DOI name="Beh">
					<DAI name="stVal" valKind="RO">
						<Val>off</Val>
					</DAI>
				</DOI>
			</LN>
			<LN lnClass="ITMI" inst="1" lnType="ITMI_zenon">
				<!--from 61850-7-4: Telemonitoring (remote monitoring) interface -->
				<DOI name="Beh">
					<DAI name="stVal" valKind="RO">
						<Val>off</Val>
					</DAI>
				</DOI>
			</LN>
			<LN lnClass="IARC" inst="1" lnType="IARC_zenon">
				<!--from 61850-7-4: Archiving interface -->
				<DOI name="Beh">
					<DAI name="stVal" valKind="RO">
						<Val>on</Val>
					</DAI>
				</DOI>
			</LN>
		</AccessPoint>
	</IED>
